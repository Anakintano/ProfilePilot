{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://profilepilot.dev/schemas/layout_classification_output.schema.json",
  "title": "VisionLayoutClassificationOutput",
  "description": "Structured output for the vision-LLM fallback. Used ONLY when local OCR/embedded-text extraction fails the confidence gate and section boundaries can't be resolved geometrically. Classifies which section a page region belongs to — it does not perform unrestricted transcription.",
  "type": "object",
  "required": ["regions"],
  "additionalProperties": false,
  "properties": {
    "regions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["region_id", "section"],
        "additionalProperties": false,
        "properties": {
          "region_id": { "type": "string" },
          "section": {
            "type": "string",
            "enum": [
              "contact",
              "summary",
              "experience",
              "education",
              "skills",
              "projects",
              "certifications",
              "other"
            ]
          },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
        }
      }
    }
  }
}
