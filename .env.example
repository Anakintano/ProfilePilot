# --- Database ---
DATABASE_URL=postgresql://profilepilot:profilepilot@localhost:5432/profilepilot
POSTGRES_USER=profilepilot
POSTGRES_PASSWORD=profilepilot
POSTGRES_DB=profilepilot

# --- Cache / rate limiting (disposable) ---
REDIS_URL=redis://localhost:6379/0

# --- Auth ---
# dev: single fixed local user, no real login required.
# supabase: verifies Supabase JWTs (requires SUPABASE_URL + SUPABASE_JWT_SECRET).
AUTH_MODE=dev
SUPABASE_URL=
SUPABASE_JWT_SECRET=

# --- Object storage ---
# local: files live under STORAGE_DIR, "signed URLs" are short-lived local API tokens.
# r2: Cloudflare R2 (not required for the local-first beta).
STORAGE_MODE=local
STORAGE_DIR=/data/uploads
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=

# --- LLM providers ---
# Leave both blank to use the deterministic fake provider (no network calls, no cost).
# Set either to switch the router to the real provider automatically.
GROQ_API_KEY=
OPENROUTER_API_KEY=

# Global (not per-user) budget on real LLM provider calls per minute, shared across
# all callers -- protects a free-tier key from a runaway loop or traffic burst.
LLM_GLOBAL_RATE_LIMIT_PER_MINUTE=20

# --- API ---
API_PORT=8000
CORS_ORIGINS=http://localhost:3000

# --- Web ---
NEXT_PUBLIC_API_URL=http://localhost:8000
